# ===========================================
# Movie Hub UI - Environment Variables
# ===========================================

# Backend API URL
VITE_API_BASE_URL=http://localhost:8080

# ===========================================
# Local Keycloak Configuration
# ===========================================
# Start Keycloak with Docker:
# docker run -p 8180:8080 -e KEYCLOAK_ADMIN=admin -e KEYCLOAK_ADMIN_PASSWORD=admin quay.io/keycloak/keycloak:latest start-dev
#
# Then follow the setup guide in README-KEYCLOAK.md

VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=movie-hub
VITE_KEYCLOAK_CLIENT_ID=movie-hub-client

# ===========================================
# Production Keycloak Configuration (Cloud IAM)
# ===========================================
# VITE_API_BASE_URL=https://rest-api-movie-hub-latest.onrender.com
# VITE_KEYCLOAK_URL=https://lemur-15.cloud-iam.com/auth
# VITE_KEYCLOAK_REALM=kotedev
# VITE_KEYCLOAK_CLIENT_ID=movie-hub-postman
